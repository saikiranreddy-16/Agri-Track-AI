NODE_ENV=staging
APP_PORT=5000
FRONTEND_URL=http://staging.agritrack-ai.com
BACKEND_URL=http://staging-api.agritrack-ai.com
LOG_LEVEL=info

MONGO_URI=mongodb://mongodb-service:27017/agri-track-staging
JWT_SECRET=staging_jwt_secret_phrase_key_value_must_be_changed_in_prod
JWT_EXPIRE=7d

# AI Configuration
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_TIMEOUT=10000
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.3
AI_TOP_P=0.9
AI_CACHE_MINUTES=10
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Security Configuration
CORS_ORIGIN=http://staging.agritrack-ai.com
REQUEST_LIMIT=2mb
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=200
REQUEST_TIMEOUT=15000

# Infrastructure Configuration
BACKUP_DIRECTORY=/var/backups/agritrack
BACKUP_RETENTION_DAYS=14
HEALTH_CHECK_INTERVAL=30000
ENABLE_SWAGGER=false
ENABLE_AI=true
ENABLE_CACHE=true
