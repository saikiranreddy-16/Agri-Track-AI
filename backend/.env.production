NODE_ENV=production
APP_PORT=5000
FRONTEND_URL=https://app.agritrack-ai.com
BACKEND_URL=https://api.agritrack-ai.com
LOG_LEVEL=info

MONGO_URI=mongodb://mongodb-service:27017/agri-track-production
JWT_SECRET=production_jwt_secret_phrase_key_value_must_be_changed_in_prod
JWT_EXPIRE=1d

# AI Configuration
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_TIMEOUT=15000
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.2
AI_TOP_P=0.9
AI_CACHE_MINUTES=10
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Security Configuration
CORS_ORIGIN=https://app.agritrack-ai.com
REQUEST_LIMIT=2mb
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
REQUEST_TIMEOUT=15000

# Infrastructure Configuration
BACKUP_DIRECTORY=/var/backups/agritrack
BACKUP_RETENTION_DAYS=30
HEALTH_CHECK_INTERVAL=30000
ENABLE_SWAGGER=false
ENABLE_AI=true
ENABLE_CACHE=true
