# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Use local MongoDB (127.0.0.1 avoids potential IPv6 resolution issues on node v17+)
MONGODB_URI=mongodb://127.0.0.1:27017/gps_db

# Authentication Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# CORS Configuration
CLIENT_URL=http://localhost:5173

# AI Configuration
AI_PROVIDER=mock
AI_MODEL=mock
AI_TIMEOUT=5000
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1000

