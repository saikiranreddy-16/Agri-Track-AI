NODE_ENV=development
APP_PORT=5000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
LOG_LEVEL=debug

MONGO_URI=mongodb://localhost:27017/agri-track-dev
JWT_SECRET=development_jwt_secret_phrase_key_value
JWT_EXPIRE=30d

# AI Configuration
AI_PROVIDER=mock
AI_MODEL=default
AI_TIMEOUT=5000
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.4
AI_TOP_P=0.9
AI_CACHE_MINUTES=10
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Security Configuration
CORS_ORIGIN=http://localhost:5173
REQUEST_LIMIT=2mb
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=1000
REQUEST_TIMEOUT=15000

# Infrastructure Configuration
BACKUP_DIRECTORY=backups
BACKUP_RETENTION_DAYS=7
HEALTH_CHECK_INTERVAL=30000
ENABLE_SWAGGER=true
ENABLE_AI=true
ENABLE_CACHE=true
